{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "packages/hooks/*"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test:frontend": "vitest run --config vitest.frontend.config.ts",
        "test:mobile": "playwright test --config=playwright.config.ts",
        "test:mobile:headed": "playwright test --config=playwright.config.ts --headed"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.2.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.4.0",
        "@types/prismjs": "^1.26.6",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "jsdom": "^29.0.0",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.2.1",
        "vite": "^7.0.7",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "@inertiajs/react": "^2.3.17",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "@web3icons/react": "^4.1.17",
        "clsx": "^2.1.1",
        "lucide-react": "^0.577.0",
        "prismjs": "^1.30.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-icons": "^5.6.0",
        "react-simple-code-editor": "^0.14.1"
    }
}
