{
  "name": "@mandate/goat-plugin",
  "version": "0.1.0",
  "description": "GOAT SDK plugin for Mandate policy-enforced on-chain tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mandate/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@goat-sdk/core": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@goat-sdk/core": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
