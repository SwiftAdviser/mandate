{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [{
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/session-scan.sh\""
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [{
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/pre-tool-gate.sh\""
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [{
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/post-validate-track.sh\""
        }]
      }
    ]
  }
}
