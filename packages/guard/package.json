{
  "name": "@mandate/guard",
  "version": "0.1.0",
  "description": "Lightweight prompt injection and credential leak detection for agent wallets",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "import": "./dist/scanner/index.js",
      "types": "./dist/scanner/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.js",
      "types": "./dist/wallet/index.d.ts"
    }
  },
  "bin": {
    "mandate-guard": "./dist/cli/scan.js"
  },
  "devDependencies": {
    "@mandate/sdk": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@mandate/sdk": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@mandate/sdk": { "optional": true }
  },
  "keywords": ["agent", "security", "prompt-injection", "guard", "mandate"],
  "license": "MIT"
}
