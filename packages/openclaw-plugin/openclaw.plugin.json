{
  "name": "mandate",
  "version": "0.2.0",
  "description": "Policy-enforced on-chain actions via Mandate spending limits",
  "main": "dist/plugin.js",
  "tools": ["mandate_transfer", "mandate_x402_pay", "mandate_send_eth"],
  "env": {
    "MANDATE_RUNTIME_KEY": {
      "description": "Your mndt_live_... or mndt_test_... key",
      "required": true
    },
    "MANDATE_PRIVATE_KEY": {
      "description": "Agent wallet private key (never exposed to LLM)",
      "required": true
    },
    "MANDATE_CHAIN_ID": {
      "description": "Default chain ID",
      "required": false,
      "default": "84532"
    }
  }
}
