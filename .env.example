APP_NAME=Mandate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mandate
DB_USERNAME=mandate
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=mandate_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@mandate.so"
MAIL_FROM_NAME="Mandate"

VITE_APP_NAME="${APP_NAME}"

# Mandate-specific
ALCHEMY_API_KEY=
COINGECKO_API_KEY=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=/auth/github/callback

REASON_SCANNER_API_BASE=https://api.venice.ai/api/v1
REASON_SCANNER_MODEL=zai-org-glm-5

MANDATE_API_BASE=http://localhost:8000
MANDATE_DASHBOARD_URL=http://localhost:5173
